# Local development — copy to `.env` in the project root (Paths A and B).
# Do not commit `.env` — it may contain secrets.
#
# Path A: ./scripts/start.sh (host app + bundled infra on 127.0.0.1)
# Path B: ./scripts/container/up.sh (local full-stack Compose)
#
# For staging/production, use `.env.production.example` instead — see docs/deployment.md.

# --- Environment label ---
APP_ENV=local

# --- Required secrets ---
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
# Must be at least 32 characters; do not use the placeholder below.
JWT_SECRET_KEY=change-me-generate-a-secure-random-value

# --- Database (PostgreSQL + asyncpg) ---
# Host app: 127.0.0.1. Path B overlay rewrites @127.0.0.1 to postgres inside the app container.
# Set POSTGRES_PASSWORD below first, then use the same password in DATABASE_URL.
DATABASE_URL=postgresql+asyncpg://todos:YOUR_POSTGRES_PASSWORD@127.0.0.1:5432/todos

# Required for bundled PostgreSQL in docker-compose.infra.yml.
POSTGRES_PASSWORD=
# POSTGRES_USER=todos
# POSTGRES_DB=todos

# --- Valkey (auth user cache — required at runtime) ---
# Started by ./scripts/start.sh or docker-compose.infra.yml on 127.0.0.1:6379.
# Path B overlay rewrites valkey://127.0.0.1:… to valkey://valkey:6379/0 inside the app container.
VALKEY_URL=valkey://127.0.0.1:6379/0
# AUTH_USER_CACHE_TTL_SECONDS=120

# --- Podman Compose (Path B) ---
# Bind API to loopback by default (set to 0.0.0.0 only if you need LAN access).
# COMPOSE_APP_BIND=127.0.0.1

# --- Container runtime ---
RUN_MIGRATIONS=true

# Optional: access token lifetime in minutes (default: 60)
# JWT_EXPIRE_MINUTES=60

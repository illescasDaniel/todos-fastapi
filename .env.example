# Local development — copy to `.env` in the project root (Paths A and B).
# Do not commit `.env` — it may contain secrets.
#
# Path A: ./scripts/start.sh (host app + bundled infra on 127.0.0.1)
# Path B: ./scripts/container/up.sh (local full-stack Compose)
#
# For staging/production, use `.env.production.example` instead — see docs/deployment.md.

# --- Environment label ---
APP_ENV=local

# --- Required secrets ---
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
# Must be at least 32 characters; do not use the placeholder below.
JWT_SECRET_KEY=change-me-generate-a-secure-random-value

# --- Ports (host bindings and local service URLs) ---
API_PORT=8000
POSTGRES_PORT=5432
VALKEY_PORT=6379
# Bind infra services to loopback (Paths A and B).
COMPOSE_INFRA_BIND=127.0.0.1
# Bind API to loopback by default (Path B; set to 0.0.0.0 only if you need LAN access).
COMPOSE_APP_BIND=127.0.0.1

# --- Database (PostgreSQL + asyncpg) ---
# Host app: 127.0.0.1. Path B overlay rewrites @127.0.0.1 to postgres inside the app container.
# Set POSTGRES_PASSWORD below first, then use the same password in DATABASE_URL.
DATABASE_URL=postgresql+asyncpg://todos:YOUR_POSTGRES_PASSWORD@127.0.0.1:${POSTGRES_PORT}/todos

# Required for bundled PostgreSQL in docker-compose.infra.yml.
POSTGRES_PASSWORD=
# POSTGRES_USER=todos
# POSTGRES_DB=todos

# --- Valkey (auth user cache — required at runtime) ---
# Started by ./scripts/start.sh or docker-compose.infra.yml on COMPOSE_INFRA_BIND:VALKEY_PORT.
# Path B overlay rewrites valkey://127.0.0.1:… to valkey://:PASSWORD@valkey:6379/0 inside the app container.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
VALKEY_PASSWORD=change-me-valkey-password
# Include the password in VALKEY_URL: valkey://:YOUR_VALKEY_PASSWORD@127.0.0.1:${VALKEY_PORT}/0
VALKEY_URL=valkey://:change-me-valkey-password@127.0.0.1:${VALKEY_PORT}/0
# AUTH_USER_CACHE_TTL_SECONDS=120

# --- Container runtime ---
RUN_MIGRATIONS=true

# Optional: access token lifetime in minutes (default: 60)
# JWT_EXPIRE_MINUTES=60

# --- MCP (Cursor todos-backend server) ---
# Defaults to http://127.0.0.1:${API_PORT} when unset; override for remote or custom hosts.
# TODOS_API_BASE_URL=http://127.0.0.1:8000

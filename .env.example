# Local development — copy to `.env` in the project root (Paths A and B).
# Do not commit `.env` — it may contain secrets.
#
# Ports and bind addresses: config/ports.env (override via config/ports.local.env).
# DATABASE_URL and VALKEY_URL are derived from ports + passwords below when unset.
#
# Path A: ./scripts/start.sh (host app + bundled infra on 127.0.0.1)
# Path B: ./scripts/container/up.sh (local full-stack Compose)
#
# For staging/production, use `.env.production.example` instead — see docs/deployment.md.

# --- Environment label ---
APP_ENV=local

# --- Required secrets ---
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
# Must be at least 32 characters; do not use the placeholder below.
JWT_SECRET_KEY=change-me-generate-a-secure-random-value

# --- Database (PostgreSQL + asyncpg) ---
# Required for bundled PostgreSQL in docker-compose.infra.yml.
POSTGRES_PASSWORD=
POSTGRES_USER=todos
POSTGRES_DB=todos

# --- Valkey (auth user cache — required at runtime) ---
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
VALKEY_PASSWORD=change-me-valkey-password
# AUTH_USER_CACHE_TTL_SECONDS=120

# --- Container runtime ---
RUN_MIGRATIONS=true

# Optional: access token lifetime in minutes (default: 60)
# JWT_EXPIRE_MINUTES=60

# --- MCP (Cursor todos-backend server) ---
# Defaults to http://${API_HOST}:${API_PORT} from config/ports.env when unset.
# TODOS_API_BASE_URL=http://127.0.0.1:8000
# Destructive MCP tools off by default (db_seed, db_wipe, stack_compose_down --remove).
# Uncomment for local dev only — see docs/mcp.md#security-defaults.
# MCP_ALLOW_DESTRUCTIVE=true

# Optional explicit overrides (production/staging or advanced local):
# DATABASE_URL=postgresql+asyncpg://todos:pass@127.0.0.1:5432/todos
# VALKEY_URL=valkey://:password@127.0.0.1:6379/0

# Staging / production — copy to `.env` on the deploy host (Path C).
# Do not commit `.env` — it may contain secrets.
#
# Deploy: ./scripts/container/deploy.sh (app-only Compose, external managed infra)
# See docs/deployment.md for the full walkthrough.
#
# Never reuse local dev secrets or values from `.env.example`.

# --- Environment label ---
APP_ENV=production
# staging — pre-production testing (same variable set as production)

# --- Required secrets ---
# Generate a unique value per environment:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change-me-generate-a-secure-random-value

# --- API (Compose host binding; container listens on API_PORT internally) ---
API_PORT=8000
# Bind API — use 0.0.0.0 behind a reverse proxy or load balancer if needed.
COMPOSE_APP_BIND=0.0.0.0

# --- Managed PostgreSQL (not 127.0.0.1) ---
# Use your provider's port in the connection string (often 5432).
DATABASE_URL=postgresql+asyncpg://user:pass@db-host.example.com:5432/todos

# --- Managed Valkey / Redis (not 127.0.0.1; auth cache required at runtime) ---
# Use your provider's port in the connection string (often 6379).
VALKEY_URL=valkey://cache-host.example.com:6379/0
# AUTH_USER_CACHE_TTL_SECONDS=120

# --- Container runtime ---
RUN_MIGRATIONS=true
# Set false if migrations run in a separate CI job before deploy.

# Optional: shorter token lifetime in production (default: 60)
# JWT_EXPIRE_MINUTES=30

# Omit ENV_FILE when vars are injected by your orchestrator instead of a file.
# ENV_FILE=.env

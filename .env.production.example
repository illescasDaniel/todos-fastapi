# Staging / production — copy to `.env` on the deploy host (Path C).
# Do not commit `.env` — it may contain secrets.
#
# Deploy: ./scripts/container/deploy.sh (app-only Compose, external managed infra)
# See docs/deployment.md for the full walkthrough.
#
# Never reuse local dev secrets or values from `.env.example`.

# --- Environment label ---
APP_ENV=production
# staging — pre-production testing (same variable set as production)

# --- Required secrets ---
# Generate a unique value per environment:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change-me-generate-a-secure-random-value

# --- API (Compose host binding; container listens on API_PORT internally) ---
API_PORT=8000
# SECURITY: Default to loopback — always place a reverse proxy (nginx, Caddy, Traefik) with TLS
# in front for any internet-facing deployment. Exposing 0.0.0.0 without TLS sends secrets in
# plain text and allows direct access bypassing rate limiting and security headers.
COMPOSE_APP_BIND=127.0.0.1
# COMPOSE_APP_BIND=0.0.0.0  # Uncomment only when behind a reverse proxy with TLS

# --- Managed PostgreSQL (not 127.0.0.1) ---
# Use your provider's port in the connection string (often 5432).
DATABASE_URL=postgresql+asyncpg://user:pass@db-host.example.com:5432/todos

# --- Managed Valkey / Redis (not 127.0.0.1; auth cache required at runtime) ---
# Use your provider's port in the connection string (often 6379).
# SECURITY: Always use rediss:// (TLS) with credentials for production managed cache services.
# Format: rediss://:PASSWORD@cache-host.example.com:6380/0
# Generate password: python -c "import secrets; print(secrets.token_urlsafe(32))"
VALKEY_PASSWORD=change-me-valkey-password
VALKEY_URL=rediss://:change-me-valkey-password@cache-host.example.com:6380/0
# AUTH_USER_CACHE_TTL_SECONDS=120

# --- Container runtime ---
# M9: Set false for production — run migrations as a one-shot pre-deploy step in CI/CD instead.
# Running on every container start is only safe for single-replica deployments.
# See docs/deployment.md for how to run migrations as a pre-deploy step.
RUN_MIGRATIONS=false

# Optional: shorter token lifetime in production (default: 60)
# JWT_EXPIRE_MINUTES=30

# Omit ENV_FILE when vars are injected by your orchestrator instead of a file.
# ENV_FILE=.env

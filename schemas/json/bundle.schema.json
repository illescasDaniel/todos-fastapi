    "LoginRequest": {
      "additionalProperties": false,
      "examples": [
        {
          "password": "changeme",
          "username": "jane"
        }
      ],
      "properties": {
        "username": {
          "maxLength": 50,
          "minLength": 2,
          "title": "Username",
          "type": "string"
        },
        "password": {
          "maxLength": 128,
          "minLength": 8,
          "title": "Password",
          "type": "string"
        }
      },
      "required": [
        "username",
        "password"
      ],
      "title": "LoginRequest",
      "type": "object"
    },
    "TokenResponse": {
      "examples": [
        {
          "access_token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
          "token_type": "bearer"
        }
      ],
      "properties": {
        "access_token": {
          "title": "Access Token",
          "type": "string"
        },
        "token_type": {
          "default": "bearer",
          "title": "Token Type",
          "type": "string"
        }
      },
      "required": [
        "access_token"
      ],
      "title": "TokenResponse",
      "type": "object"
    },
